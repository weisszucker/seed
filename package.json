{
  "name": "seed",
  "version": "1.0.0",
  "description": "Seed terminal markdown editor",
  "bin": {
    "seed": "./bin/seed"
  },
  "type": "module",
  "scripts": {
    "setup": "bash ./setup.sh",
    "start": "bun run src/index.tsx",
    "dev": "bun run --watch src/index.tsx",
    "build": "tsc"
  },
  "dependencies": {
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "react": "^19.0.0",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
